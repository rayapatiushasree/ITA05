      "source": [
        "from PIL import Image\n",
        "import matplotlib.pyplot as plt\n",
        "\n",
        "# Load the image\n",
        "image_path = '/content/images.jpeg'\n",
        "original_image = Image.open(image_path)\n",
        "\n",
        "print(f\"Original image size: {original_image.size}\")\n",
        "\n",
        "# Define new sizes\n",
        "smaller_size = (original_image.width // 2, original_image.height // 2) # Half the original size\n",
        "bigger_size = (original_image.width * 2, original_image.height * 2)   # Double the original size\n",
        "\n",
        "# Resize the image to a smaller size\n",
        "smaller_image = original_image.resize(smaller_size)\n",
        "print(f\"Smaller image size: {smaller_image.size}\")\n",
        "\n",
        "# Resize the image to a bigger size\n",
        "bigger_image = original_image.resize(bigger_size)\n",
        "print(f\"Bigger image size: {bigger_image.size}\")\n",
        "\n",
        "# Display the images\n",
        "fig, axes = plt.subplots(1, 3, figsize=(15, 5))\n",
        "\n",
        "axes[0].imshow(original_image)\n",
        "axes[0].set_title(f'Original (Size: {original_image.size})')\n",
        "axes[0].axis('off')\n",
        "\n",
        "axes[1].imshow(smaller_image)\n",
        "axes[1].set_title(f'Smaller (Size: {smaller_image.size})')\n",
        "axes[1].axis('off')\n",
        "\n",
        "axes[2].imshow(bigger_image)\n",
        "axes[2].set_title(f'Bigger (Size: {bigger_image.size})')\n",
        "axes[2].axis('off')\n",
        "\n",
        "plt.tight_layout()\n",
        "plt.show()"
      ],
