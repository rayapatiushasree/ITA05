      },
      "source": [
        "import cv2\n",
        "import numpy as np\n",
        "from google.colab.patches import cv2_imshow # For displaying images in Colab\n",
        "\n",
        "# Load the image\n",
        "image_path = '/content/images.jpg'\n",
        "image = cv2.imread(image_path)\n",
        "\n",
        "if image is None:\n",
        "    print(f\"Error: Unable to load image from {image_path}\")\n",
        "else:\n",
        "    # Display original image\n",
        "    print(\"Original Image:\")\n",
        "    cv2_imshow(image)\n",
        "\n",
        "    # Define 4 source points (corners of the area you want to transform) in the original image\n",
        "    # These are placeholder values. You will need to adjust them to the actual corners\n",
        "    # of the object/area you want to transform in your image.\n",
        "    # Example: Top-left, Top-right, Bottom-right, Bottom-left\n",
        "    src_pts = np.float32([\n",
        "        [100, 100],  # Top-left\n",
        "        [500, 100],  # Top-right\n",
        "        [600, 400],  # Bottom-right\n",
        "        [50, 400]    # Bottom-left\n",
        "    ])\n",
        "\n",
        "    # Define 4 corresponding destination points (where the corners should go) in the new image\n",
        "    # This will determine the shape and perspective of the transformed region.\n",
        "    # Example: A perfect rectangle\n",
        "    width = 400\n",
        "    height = 300\n",
        "    dst_pts = np.float32([\n",
        "        [0, 0],             # Top-left\n",
        "        [width - 1, 0],     # Top-right\n",
        "        [width - 1, height - 1], # Bottom-right\n",
        "        [0, height - 1]     # Bottom-left\n",
        "    ])\n",
        "\n",
        "    # Get the perspective transformation matrix\n",
        "    M = cv2.getPerspectiveTransform(src_pts, dst_pts)\n",
        "\n",
        "    # Apply the perspective transformation to the image\n",
        "    transformed_image = cv2.warpPerspective(image, M, (width, height))\n",
        "\n",
        "    # Display the transformed image\n",
        "    print(\"\\nTransformed Image:\")\n",
        "    cv2_imshow(transformed_image)\n"
      ],
      "execution_count": 1,
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "Original Image:\n"
          ]
        },
